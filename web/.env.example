# DeepTutor backend used by the SaaS-facing course flow.
# Point this at the Python backend, for example: http://localhost:8001
DEEPTUTOR_URL=http://localhost:8001
NEXT_PUBLIC_API_BASE=http://localhost:8001

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=true
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Optional API key forwarded as Authorization / X-API-Key when your DeepTutor
# deployment is protected by a proxy or gateway. The local OSS server does not
# require it by default.
DEEPTUTOR_API_KEY=
