# DeepTutor backend used by the SaaS-facing course flow.
# Point this at the Python backend, for example: http://localhost:8001
# If your backend uses Gemini internally, no Gemini key is needed here unless
# a proxy in front of DeepTutor requires DEEPTUTOR_API_KEY.
DEEPTUTOR_URL=http://localhost:8001
NEXT_PUBLIC_API_BASE=http://localhost:8001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=true
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Optional API key forwarded as Authorization / X-API-Key when your DeepTutor
# deployment is protected by a proxy or gateway. The local OSS server does not
# require it by default.
DEEPTUTOR_API_KEY=

# Postgres persistence for billing, usage, and courses.
# Production requires DATABASE_URL or POSTGRES_URL. Local development can omit
# this and use the file fallback, but production APIs fail closed without it.
DATABASE_URL=
POSTGRES_URL=

# Stripe billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_TEAM_PRICE_ID=price_your_team_price_id

# Optional version-badge release lookup tuning
NEXT_PUBLIC_GITHUB_REPO=g4m35/tuto
GITHUB_TOKEN=
