{
  "name": "opentutor-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev",
    "dev:turbo": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "perf:check": "node ./scripts/route_budgets.mjs",
    "build:perf": "npm run build && npm run perf:check",
    "i18n:parity": "node ./scripts/i18n_parity.mjs",
    "i18n:audit": "node ./scripts/i18n_audit.mjs",
    "i18n:audit:strict": "node ./scripts/i18n_audit.mjs --strict",
    "i18n:check": "npm run i18n:parity && npm run i18n:audit",
    "audit": "playwright test --project=ui-audit",
    "audit:ui": "playwright test --ui --project=ui-audit",
    "audit:report": "playwright show-report"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.2.3",
    "@stripe/stripe-js": "^9.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.2",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.0.6",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shadcn": "^4.4.0",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
