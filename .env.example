# ============================================
# DeepTutor Environment Template
# ============================================
# Copy this file to `.env` and fill in your values.
# Core runtime settings are grouped as:
# ports / llm / embedding / search / docker-cloud / security

# --------------------------------------------
# Ports
# --------------------------------------------
# Local launches use BACKEND_PORT / FRONTEND_PORT.
# Hosted platforms like Railway inject PORT automatically for the backend.
BACKEND_PORT=8001
FRONTEND_PORT=3782

# --------------------------------------------
# Clerk Authentication (Optional for SaaS wrapper)
# --------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=true
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --------------------------------------------
# LLM (Required)
# --------------------------------------------
# Supported bindings: openai, lm_studio, ollama, azure_openai, deepseek, ...
# For a full list run: deeptutor provider list // README
# If you run Gemini for both chat and embeddings, you can reuse the same
# Google AI Studio key across LLM_API_KEY, EMBEDDING_API_KEY, GEMINI_API_KEY,
# and GOOGLE_API_KEY. The runtime also accepts GEMINI_API_KEY / GOOGLE_API_KEY
# as compatibility fallbacks when LLM_BINDING=gemini.
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_HOST=https://api.openai.com/v1
LLM_API_VERSION=

# --------------------------------------------
# Embedding (Required for knowledge base features)
# --------------------------------------------
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_HOST=https://api.openai.com/v1
EMBEDDING_DIMENSION=3072
EMBEDDING_API_VERSION=

# --------------------------------------------
# Gemini example (reuse one key across chat + embeddings)
# --------------------------------------------
# LLM_BINDING=gemini
# LLM_MODEL=gemini-2.5-pro
# LLM_API_KEY=your-google-ai-studio-key
# LLM_HOST=https://generativelanguage.googleapis.com/v1beta/openai/
# EMBEDDING_BINDING=gemini
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_API_KEY=your-google-ai-studio-key
# EMBEDDING_HOST=https://generativelanguage.googleapis.com/v1beta/openai/
# EMBEDDING_DIMENSION=3072
# GEMINI_API_KEY=your-google-ai-studio-key
# GOOGLE_API_KEY=your-google-ai-studio-key

# ⚠️  Docker + local LLM (LM Studio / Ollama / vLLM)
# ─────────────────────────────────────────────────────
# When running DeepTutor in Docker and your LLM runs on the HOST machine:
#   - Do NOT use "localhost" or "127.0.0.1" — inside the container these
#     refer to the container itself, not the host.
#   - macOS / Windows Docker Desktop: use http://host.docker.internal:<port>/v1
#   - Linux: use the host's LAN IP, e.g. http://192.168.1.100:<port>/v1
#     (or run Docker with --network=host)
#
# Example (LM Studio on port 1234):
#   LLM_BINDING=lm_studio
#   LLM_HOST=http://host.docker.internal:1234/v1
#   EMBEDDING_BINDING=lm_studio
#   EMBEDDING_HOST=http://host.docker.internal:1234/v1

# --------------------------------------------
# Web Search (Optional)
# --------------------------------------------
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# --------------------------------------------
# Docker / Cloud deployment (Optional)
# --------------------------------------------
# Public backend URL used by the frontend when deployed remotely.
NEXT_PUBLIC_API_BASE_EXTERNAL=
# Alternative direct API base URL.
NEXT_PUBLIC_API_BASE=
# Backend URL consumed by the SaaS-facing course flow in web/.
DEEPTUTOR_URL=
# Optional API key for protected backend deployments.
DEEPTUTOR_API_KEY=
# Optional GHCR image override for docker-compose.ghcr.yml.
GHCR_IMAGE=
# Optional aliases for Gemini setups that keep one Google AI Studio key around.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# --------------------------------------------
# Stripe Billing (Optional for SaaS wrapper)
# --------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx

# --------------------------------------------
# Security / Networking (Optional)
# --------------------------------------------
# Keep this false in production.
DISABLE_SSL_VERIFY=false
